<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Book Availability | Bernard Finlay Memorial Library</title>
<meta name="description" content="Check which books are currently available or in use at the library.">
<style>
  :root {
    --navy:#12355b;
    --teal:#167d7f;
    --gold:#c8a96a;
    --ink:#243041;
    --muted:#667085;
    --bg:#f7f5ef;
    --card:#ffffff;
    --line:#e6dfd1;
    --green:#16794c;
    --red:#b42318;
    --shadow:0 16px 40px rgba(18,53,91,.10);
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:Arial,Helvetica,sans-serif;background:var(--bg);color:var(--ink);line-height:1.5}
  header{background:linear-gradient(135deg,var(--navy),#0d2743);color:white;padding:48px 20px 42px;text-align:center}
  .wrap{max-width:1180px;margin:0 auto;padding:0 20px}
  h1{margin:0;font-size:clamp(32px,5vw,54px);letter-spacing:-.03em}
  .subtitle{max-width:780px;margin:14px auto 0;color:#dce8f2;font-size:18px}
  .notice{margin:26px auto 0;display:inline-block;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.25);padding:10px 16px;border-radius:999px;font-size:14px;color:#fff}
  .toolbar{background:#fff;border:1px solid var(--line);box-shadow:var(--shadow);border-radius:18px;padding:18px;margin-top:-28px;position:relative;z-index:2}
  .controls{display:grid;grid-template-columns:1.4fr .8fr .8fr auto;gap:12px;align-items:end}
  label{font-size:13px;font-weight:700;color:var(--navy);display:block;margin-bottom:6px}
  input,select{width:100%;padding:12px 13px;border:1px solid var(--line);border-radius:12px;background:#fff;font-size:15px;color:var(--ink)}
  button{border:0;border-radius:12px;padding:13px 18px;font-weight:700;cursor:pointer;background:var(--teal);color:white;font-size:15px}
  button:hover{filter:brightness(.95)}
  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:22px 0 26px}
  .stat{background:#fff;border:1px solid var(--line);border-radius:16px;padding:18px;box-shadow:0 8px 22px rgba(18,53,91,.05)}
  .stat .num{font-size:28px;font-weight:800;color:var(--navy)}
  .stat .lab{font-size:13px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.05em}
  .results-head{display:flex;justify-content:space-between;align-items:center;gap:16px;margin:20px 0 16px}
  .results-head h2{margin:0;color:var(--navy);font-size:24px}
  .view-note{font-size:14px;color:var(--muted)}
  .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;padding-bottom:50px}
  .book{background:var(--card);border:1px solid var(--line);border-radius:18px;overflow:hidden;box-shadow:0 8px 24px rgba(18,53,91,.07);display:flex;flex-direction:column;min-height:100%}
  .cover{height:180px;background:linear-gradient(145deg,#eef3f7,#fff7e7);display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--line);position:relative}
  .cover img{width:100%;height:100%;object-fit:cover;display:block}
  .placeholder{width:78px;height:96px;border-radius:10px;border:2px dashed #cdbf9c;display:flex;align-items:center;justify-content:center;font-size:38px;background:rgba(255,255,255,.55)}
  .pic-hint{position:absolute;bottom:8px;left:10px;right:10px;text-align:center;font-size:11px;color:var(--muted);background:rgba(255,255,255,.75);padding:3px 6px;border-radius:999px}
  .book-body{padding:15px;display:flex;flex-direction:column;gap:7px;flex:1}
  .title{font-weight:800;color:var(--navy);font-size:16px;line-height:1.25}
  .author{color:var(--muted);font-size:14px}
  .meta{display:flex;gap:6px;flex-wrap:wrap;margin-top:auto;padding-top:8px}
  .pill{font-size:12px;font-weight:700;padding:5px 8px;border-radius:999px;background:#f2f4f7;color:#475467}
  .available{background:#eaf7ef;color:var(--green)}
  .inuse{background:#fff1f0;color:var(--red)}
  .arrived{background:#fff7dc;color:#8a5a00}
  .unknown{background:#f2f4f7;color:#475467}
  .empty{background:#fff;border:1px dashed var(--line);border-radius:18px;padding:32px;text-align:center;color:var(--muted);grid-column:1/-1}
  footer{background:#0d2743;color:#dce8f2;text-align:center;padding:28px 20px;font-size:14px}
  footer strong{color:#fff}
  .admin-note{background:#fff8e6;border:1px solid #efd79b;color:#6f4e00;border-radius:14px;padding:14px 16px;margin-bottom:22px;font-size:14px}
  .admin-note code{background:#fff;border:1px solid #ead8a5;padding:1px 5px;border-radius:5px}
  @media(max-width:980px){.grid{grid-template-columns:repeat(3,1fr)}.controls{grid-template-columns:1fr 1fr}.stats{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:680px){header{padding:34px 16px}.wrap{padding:0 14px}.toolbar{margin-top:-18px}.controls{grid-template-columns:1fr}.grid{grid-template-columns:1fr}.stats{grid-template-columns:1fr 1fr}.cover{height:210px}}
</style>
</head>
<body>
<header>
  <div class="wrap">
    <h1>Book Availability</h1>
    <p class="subtitle">Search the library catalogue to see which books are available now and which are currently in use.</p>
    <div class="notice">Adult books: 5 shekel · Hebrew books: 1 shekel · Call 054-848-1728 / 02-582-3090</div>
  </div>
</header>

<main class="wrap">
  <section class="toolbar" aria-label="Book search and filters">
    <div class="controls">
      <div>
        <label for="search">Search by title or author</label>
        <input id="search" type="search" placeholder="Start typing a book name, author, or Hebrew title...">
      </div>
      <div>
        <label for="category">Category</label>
        <select id="category"><option value="all">All categories</option></select>
      </div>
      <div>
        <label for="status">Availability</label>
        <select id="status">
          <option value="all">All</option>
          <option value="Available">Available</option>
          <option value="In use">In use</option>
          <option value="Just arrived">Just arrived</option>
        </select>
      </div>
      <button type="button" onclick="resetFilters()">Reset</button>
    </div>
  </section>

  <section class="stats" aria-label="Catalogue summary">
    <div class="stat"><div class="num" id="totalCount">0</div><div class="lab">Total books</div></div>
    <div class="stat"><div class="num" id="availableCount">0</div><div class="lab">Available</div></div>
    <div class="stat"><div class="num" id="inUseCount">0</div><div class="lab">In use</div></div>
    <div class="stat"><div class="num" id="shownCount">0</div><div class="lab">Showing</div></div>
  </section>

  <div class="admin-note">
    <strong>Picture space included:</strong> each card has a cover area. To add a real picture later, edit the book in the <code>BOOKS</code> list and paste an image link into its <code>image</code> field.
  </div>

  <div class="results-head">
    <h2>Catalogue</h2>
    <div class="view-note" id="viewNote">Showing all books</div>
  </div>
  <section class="grid" id="bookGrid" aria-live="polite"></section>
</main>

<footer>
  <strong>Bernard Finlay Memorial Library</strong><br>
  Yirmiyahu Hanavi 16/8, Floor 1
</footer>

