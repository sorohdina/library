  .bar{position:sticky;top:0;z-index:20;background:rgba(246,248,252,.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--line);padding:16px 20px;}
  .controls{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:12px;align-items:center;}
  input,select{width:100%;padding:13px 14px;border:1px solid var(--line);border-radius:12px;background:white;color:var(--ink);font-size:15px;outline:none;}
  input:focus,select:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(26,139,134,.12);}
  main{padding:28px 20px 64px;}
  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px;}
  .stat{background:white;border:1px solid var(--line);border-radius:16px;padding:18px;box-shadow:0 8px 22px rgba(16,25,59,.05);}
  .stat strong{display:block;font-size:28px;color:var(--navy);}
  .stat span{color:var(--muted);font-size:14px;}
  .note{background:#FFF8E8;border:1px solid #F0D9A4;color:#664D03;border-radius:16px;padding:14px 16px;margin-bottom:22px;font-size:14px;}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:18px;}
  .book{background:white;border:1px solid var(--line);border-radius:20px;overflow:hidden;box-shadow:var(--shadow);display:flex;flex-direction:column;min-height:420px;}
  .cover{height:220px;background:linear-gradient(135deg,#E9EEF8,#FFFFFF);display:flex;align-items:center;justify-content:center;position:relative;border-bottom:1px solid var(--line);}
  .cover img{max-height:205px;max-width:145px;width:auto;border-radius:8px;box-shadow:0 12px 28px rgba(16,25,59,.22);background:white;}
  .placeholder{width:145px;height:205px;border-radius:10px;background:linear-gradient(135deg,var(--navy),var(--teal));display:flex;align-items:center;justify-content:center;text-align:center;color:white;padding:18px;font-weight:700;font-size:16px;box-shadow:0 12px 28px rgba(16,25,59,.20);}
  .cover-status{position:absolute;top:12px;left:12px;padding:5px 9px;border-radius:999px;font-size:11px;font-weight:700;background:white;color:var(--muted);box-shadow:0 5px 15px rgba(16,25,59,.08);}
  .body{padding:16px;display:flex;flex-direction:column;gap:8px;flex-grow:1;}
  .title{font-weight:800;color:var(--navy);font-size:17px;line-height:1.25;}
  .author{color:var(--muted);font-size:14px;}
  .meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:3px;}
  .pill{font-size:12px;padding:5px 9px;border-radius:999px;background:var(--soft);color:var(--muted);border:1px solid var(--line);}
  .status{font-size:13px;font-weight:800;margin-top:auto;padding:10px 12px;border-radius:12px;text-align:center;}
  .available{background:#EAF7EE;color:var(--green);}
  .inuse{background:#FDECEC;color:var(--red);}
  .new{background:#EBF2FF;color:var(--blue);}
  .unknown{background:#F3F4F6;color:#4B5563;}
  .rtl{direction:rtl;text-align:right;}
  .empty{display:none;text-align:center;background:white;border:1px solid var(--line);border-radius:18px;padding:32px;margin-top:18px;color:var(--muted);}
  footer{padding:28px 20px;color:var(--muted);text-align:center;border-top:1px solid var(--line);background:white;}
  .small{font-size:12px;color:var(--muted);}
  @media(max-width:800px){.controls{grid-template-columns:1fr 1fr;}.stats{grid-template-columns:1fr 1fr;}}
  @media(max-width:520px){.controls{grid-template-columns:1fr;}.stats{grid-template-columns:1fr;}header{padding-top:32px;}.book{min-height:auto;}}
</style>
</head>
