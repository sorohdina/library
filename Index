const CATEGORIES = ["Biographies", "ChildrensTeens", "Fiction", "Holocaust", "Just arrived", "Non Fiction", "True Short Stories", "ספרים בעברית"];

const searchInput = document.getElementById('search');
const categorySelect = document.getElementById('category');
const statusSelect = document.getElementById('status');
const grid = document.getElementById('bookGrid');

function escapeHtml(text) {
  return String(text || '').replace(/[&<>"']/g, function(ch) {
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch];
  });
}

function statusClass(status) {
  if (status === 'Available') return 'available';
  if (status === 'In use') return 'inuse';
  if (status === 'Just arrived') return 'arrived';
  return 'unknown';
}

function populateCategories() {
  CATEGORIES.forEach(function(cat) {
    const option = document.createElement('option');
    option.value = cat;
    option.textContent = cat;
    categorySelect.appendChild(option);
  });
}

function getFilteredBooks() {
  const q = searchInput.value.trim().toLowerCase();
  const cat = categorySelect.value;
  const status = statusSelect.value;
  return BOOKS.filter(function(book) {
    const text = [book.title, book.author, book.category, book.subcategory].join(' ').toLowerCase();
    const matchesSearch = !q || text.includes(q);
    const matchesCategory = cat === 'all' || book.category === cat;
    const matchesStatus = status === 'all' || book.status === status;
    return matchesSearch && matchesCategory && matchesStatus;
  });
}

function renderBooks() {
  const books = getFilteredBooks();
  document.getElementById('shownCount').textContent = books.length;
  document.getElementById('viewNote').textContent = books.length === BOOKS.length ? 'Showing all books' : 'Showing ' + books.length + ' matching books';
  if (!books.length) {
    grid.innerHTML = '<div class="empty"><strong>No books found.</strong><br>Try a different search or filter.</div>';
    return;
  }
  grid.innerHTML = books.map(function(book) {
    const image = book.image ? '<img src="' + escapeHtml(book.image) + '" alt="Cover of ' + escapeHtml(book.title) + '">' : '<div class="placeholder">📚</div><div class="pic-hint">Cover picture can be added</div>';
    const sub = book.subcategory ? '<span class="pill">' + escapeHtml(book.subcategory) + '</span>' : '';
    return '<article class="book" dir="auto">' +
      '<div class="cover">' + image + '</div>' +
      '<div class="book-body">' +
        '<div class="title">' + escapeHtml(book.title) + '</div>' +
        (book.author ? '<div class="author">' + escapeHtml(book.author) + '</div>' : '') +
        '<div class="meta">' +
          '<span class="pill ' + statusClass(book.status) + '">' + escapeHtml(book.status) + '</span>' +
          '<span class="pill">' + escapeHtml(book.category) + '</span>' + sub +
        '</div>' +
      '</div>' +
    '</article>';
  }).join('');
}

function updateStats() {
  document.getElementById('totalCount').textContent = BOOKS.length;
  document.getElementById('availableCount').textContent = BOOKS.filter(b => b.status === 'Available' || b.status === 'Just arrived').length;
  document.getElementById('inUseCount').textContent = BOOKS.filter(b => b.status === 'In use').length;
}

function resetFilters() {
  searchInput.value = '';
  categorySelect.value = 'all';
  statusSelect.value = 'all';
  renderBooks();
}

searchInput.addEventListener('input', renderBooks);
categorySelect.addEventListener('change', renderBooks);
statusSelect.addEventListener('change', renderBooks);

populateCategories();
updateStats();
renderBooks();
</script>
