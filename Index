<script>
const BOOKS = JSON.parse(document.getElementById('bookData').textContent);
const grid = document.getElementById('grid');
const searchEl = document.getElementById('search');
const categoryEl = document.getElementById('category');
const statusEl = document.getElementById('status');
const sortEl = document.getElementById('sort');
const emptyEl = document.getElementById('empty');
const coverCacheKey = 'bfml-cover-cache-v2';
let visibleBooks = [];
let observer;
let coverCache = {};
try { coverCache = JSON.parse(localStorage.getItem(coverCacheKey) || '{}'); } catch(e) { coverCache = {}; }
function saveCoverCache() { try { localStorage.setItem(coverCacheKey, JSON.stringify(coverCache)); } catch(e) {} }
function normalise(text) { return (text || '').toString().toLowerCase().trim(); }
function coverKey(book) { return (book.title + '|' + book.author).toLowerCase(); }
function statusClass(status) { const s = normalise(status); if (s.includes('available')) return 'available'; if (s.includes('in use')) return 'inuse'; if (s.includes('just arrived')) return 'new'; return 'unknown'; }
function escapeHtml(text) { return (text || '').toString().replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[ch])); }
function setupFilters() { [...new Set(BOOKS.map(b => b.category).filter(Boolean))].sort((a,b)=>a.localeCompare(b)).forEach(cat => { const opt=document.createElement('option'); opt.value=cat; opt.textContent=cat; categoryEl.appendChild(opt); }); }
function render() {
  const q = normalise(searchEl.value), cat = categoryEl.value, st = statusEl.value;
  let rows = BOOKS.filter(b => { const hay = normalise([b.title,b.author,b.category,b.subtype,b.status].join(' ')); return (!q || hay.includes(q)) && (cat==='all' || b.category===cat) && (st==='all' || b.status===st); });
  const sort=sortEl.value; rows.sort((a,b)=>(a[sort]||'').localeCompare(b[sort]||'')); visibleBooks=rows;
  document.getElementById('totalCount').textContent=rows.length;
  document.getElementById('availableCount').textContent=rows.filter(b=>b.status==='Available').length;
  document.getElementById('inUseCount').textContent=rows.filter(b=>b.status==='In use').length;
  document.getElementById('newCount').textContent=rows.filter(b=>b.status==='Just arrived').length;
  grid.innerHTML = rows.map(book => {
    const cls=statusClass(book.status); const rtl=book.rtl?' rtl':'';
    return `<article class="book${rtl}"><div class="cover" data-cover-id="${escapeHtml(book.id)}"><span class="cover-status">${escapeHtml(book.status)}</span><div class="placeholder">${escapeHtml(book.title)}</div></div><div class="body"><div class="title">${escapeHtml(book.title)}</div><div class="author">${book.author ? 'by '+escapeHtml(book.author) : 'Author not listed'}</div><div class="meta"><span class="pill">${escapeHtml(book.category)}</span>${book.subtype && book.subtype!==book.category ? `<span class="pill">${escapeHtml(book.subtype)}</span>` : ''}</div><div class="status ${cls}">${escapeHtml(book.status)}</div></div></article>`;
  }).join('');
  emptyEl.style.display = rows.length ? 'none' : 'block'; observeCovers();
}
function observeCovers() { if(observer) observer.disconnect(); observer = new IntersectionObserver(entries => { entries.forEach(entry => { if(entry.isIntersecting) { const cover=entry.target; observer.unobserve(cover); const book=visibleBooks.find(b=>b.id===cover.dataset.coverId); if(book) loadCover(book, cover); } }); }, {rootMargin:'250px'}); document.querySelectorAll('.cover').forEach(c=>observer.observe(c)); }
async function loadCover(book, coverEl) {
  const key=coverKey(book); if(book.manualImage) return setCover(coverEl, book.manualImage, book.title); if(coverCache[key]) { if(coverCache[key] !== 'none') setCover(coverEl, coverCache[key], book.title); return; }
  const titleQ=(book.title||'').replace(/\([^)]*\)/g,'').trim(); const q=encodeURIComponent('intitle:' + titleQ + (book.author ? ' inauthor:' + book.author : ''));
  try { const res=await fetch('https://www.googleapis.com/books/v1/volumes?q='+q+'&maxResults=1&printType=books&projection=lite'); if(!res.ok) throw new Error('cover lookup failed'); const data=await res.json(); let img=data.items && data.items[0] && data.items[0].volumeInfo && data.items[0].volumeInfo.imageLinks && (data.items[0].volumeInfo.imageLinks.thumbnail || data.items[0].volumeInfo.imageLinks.smallThumbnail); if(img) { img=img.replace('http://','https://'); coverCache[key]=img; saveCoverCache(); setCover(coverEl,img,book.title); } else { coverCache[key]='none'; saveCoverCache(); } } catch(e) { coverCache[key]='none'; saveCoverCache(); }
}
function setCover(coverEl, src, label) { const img=document.createElement('img'); img.src=src; img.alt=label || 'Book cover'; img.loading='lazy'; img.onerror=function(){this.remove();}; const ph=coverEl.querySelector('.placeholder'); if(ph) ph.remove(); coverEl.appendChild(img); }
[searchEl, categoryEl, statusEl, sortEl].forEach(el => el.addEventListener('input', render));
setupFilters(); render();
</script>
